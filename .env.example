# ============================================================
# Medical Healthcare RAG — Environment Contract
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Fireworks AI (LLM generation)
# Get key at: https://app.fireworks.ai/settings/users/api-keys
# ------------------------------------------------------------
FIREWORKS_API_KEY=fw_your_key_here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct

# ------------------------------------------------------------
# Weaviate (vector DB)
# Local default: http://localhost:8080
# Cloud: https://your-cluster.weaviate.network
# ------------------------------------------------------------
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=

# ------------------------------------------------------------
# Google AI Studio — multimodal embeddings
# Get a free API key at: https://aistudio.google.com/apikey
# No GCP project or service account needed.
# ------------------------------------------------------------
GEMINI_API_KEY=AIza_your_key_here
GEMINI_EMBEDDING_MODEL=gemini-embedding-exp-03-07

# ------------------------------------------------------------
# Prompt versioning
# ------------------------------------------------------------
PROMPT_VERSION=v1

# ------------------------------------------------------------
# Retrieval tuning
# ------------------------------------------------------------
RETRIEVAL_TOP_K=5
HYBRID_ALPHA=0.5
RERANK_TOP_M=20
RERANK_TOP_K=5

# ------------------------------------------------------------
# App
# ------------------------------------------------------------
APP_ENV=development
TESTING=false
